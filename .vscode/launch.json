{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Launch ingester",
      "type": "go",
      "request": "launch",
      "mode": "debug",
      "program": "${workspaceFolder}/cmd/ingester",
      "env": {
        "SOURCE_FILE": "${workspaceFolder}/config/ingester/feeds.json"
      }
    },
    {
      "name": "Launch worker",
      "type": "go",
      "request": "launch",
      "mode": "debug",
      "program": "${workspaceFolder}/cmd/worker",
      "env": {
        "HTML_STORAGE_DIR": "/tmp/data"
      }
    }
  ],
  "compounds": [
    {
      "name": "Launch both ingester and worker",
      "configurations": [
        "Launch worker",
        "Launch ingester"
      ]
    }
  ]
}
